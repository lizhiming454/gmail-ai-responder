# Gmail OAuth2 credentials file path (from Google Cloud Console)
GOOGLE_CREDENTIALS_FILE=config/credentials.json

# OpenAI API key
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Model to use (gpt-4o recommended)
OPENAI_MODEL=gpt-4o

# How often to check for new emails (seconds)
POLL_INTERVAL=60

# Label applied after auto-reply
PROCESSED_LABEL=AUTO_REPLIED

# Max emails processed per run (safety cap)
MAX_PER_RUN=10
